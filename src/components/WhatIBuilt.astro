---
const items = [
  {
    num: '01',
    name: 'Prompt Builder',
    type: 'Film-Grade Prompt Tool',
    body: 'BYOK prompt engine built for Midjourney, Flux, Runway, and NanoBanana. Chip-based preset system with AI agent that writes finished prompts as a creative partner.',
    url: 'https://ai.drsfilms.com/prompt-builder/prompt-builder.html',
    tag: 'Open Source · Live',
  },
  {
    num: '02',
    name: 'AI Canvas Studio',
    type: 'Video Generation Pipeline',
    body: 'G0–G7 gated pipeline from script to screen. Breakdown → treatment → look bible → shot design → generation → review. 5 AI-native shorts shipped in under 4 weeks.',
    url: 'https://video-canvas.pages.dev',
    tag: 'G0–G7 Gates · Live',
  },
  {
    num: '03',
    name: 'Film Budget Studio',
    type: "Producer's Budget Tool",
    body: 'React + Supabase. Built for the way producers actually think about money — top sheet, line items, co-production splits. Not Excel.',
    url: 'https://film-budget-studio.pages.dev',
    tag: 'React · Supabase · Beta',
  },
  {
    num: '04',
    name: 'ttl-breakdown',
    type: 'Script Breakdown Tool',
    body: '245 scenes · 2,961 items digitized for 流俗地 / This Timeworn Land. Cloudflare D1 + Workers. Built to generalize into a multi-project product.',
    url: 'https://ttl.sentimentalargument.com',
    tag: 'D1 · Workers · Live',
  },
];
---

<section class="section section--alt built" id="built">
  <div class="section__inner">
    <p class="eyebrow reveal">Tools, not demos</p>
    <h2 class="section__title reveal reveal--title">What I Built</h2>

    <div class="built__grid">
      {items.map((it) => (
        <article class="card reveal reveal--card" data-url={it.url || ''}>
          <div class="card__head">
            <span class="card__num">{it.num}</span>
            <span class="card__type">{it.type}</span>
          </div>
          <h3 class="card__name">{it.name}</h3>
          <p class="card__body">{it.body}</p>
          <div class="card__footer">
            <span class="card__tag">{it.tag}</span>
            {it.url && (
              <button
                class="card__demo"
                data-url={it.url}
                data-title={it.name}
                aria-label={`Open ${it.name} live demo`}
              >
                Live Demo ↗
              </button>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- iframe modal -->
<div id="demo-modal" class="demo-modal" role="dialog" aria-modal="true" aria-label="Live demo" hidden>
  <div class="demo-modal__bar">
    <span id="demo-modal-title" class="demo-modal__title"></span>
    <div class="demo-modal__actions">
      <a id="demo-modal-link" href="#" target="_blank" rel="noopener noreferrer" class="demo-modal__open">Open ↗</a>
      <button id="demo-modal-close" class="demo-modal__close" aria-label="Close demo">✕</button>
    </div>
  </div>
  <iframe
    id="demo-frame"
    src=""
    class="demo-modal__frame"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope"
    loading="lazy"
    title="Live demo"
  ></iframe>
  <div id="demo-modal-blocked" class="demo-modal__blocked" hidden>
    <p>This tool blocks embedding — <a id="demo-modal-blocked-link" href="#" target="_blank" rel="noopener noreferrer">open in new tab ↗</a></p>
  </div>
</div>
<div id="demo-overlay" class="demo-overlay" hidden></div>

<style>
  .built__grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .card {
    background: var(--bg-2);
    padding: clamp(28px, 3.5vw, 48px);
    transition: background 0.35s var(--ease);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .card:hover { background: var(--bg-3, #1a1714); }
  .card:hover .card__name { color: var(--amber); }

  .card__head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }
  .card__num {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--amber-d);
  }
  .card__type {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .card__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(26px, 3vw, 34px);
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 14px;
    letter-spacing: -0.005em;
    transition: color 0.3s var(--ease);
  }
  .card__body {
    font-family: var(--font-ui);
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
    flex: 1;
    margin-bottom: 24px;
  }
  .card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    gap: 12px;
  }
  .card__tag {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .card__demo {
    background: transparent;
    border: 1px solid var(--amber-d);
    color: var(--amber);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 7px 16px;
    cursor: pointer;
    transition: background 0.25s var(--ease), color 0.25s var(--ease), border-color 0.25s var(--ease);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .card__demo:hover {
    background: var(--amber);
    color: var(--bg);
    border-color: var(--amber);
  }

  /* modal */
  .demo-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8, 6, 4, 0.75);
    backdrop-filter: blur(4px);
    z-index: 900;
  }
  .demo-overlay[hidden] { display: none; }

  .demo-modal {
    position: fixed;
    inset: 24px;
    z-index: 901;
    display: flex;
    flex-direction: column;
    background: var(--bg-2);
    border: 1px solid var(--rule);
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
  }
  .demo-modal[hidden] { display: none; }

  .demo-modal__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
  }
  .demo-modal__title {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .demo-modal__actions { display: flex; align-items: center; gap: 16px; }
  .demo-modal__open {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .demo-modal__open:hover { color: var(--cream); }
  .demo-modal__close {
    background: transparent;
    border: none;
    color: var(--text-dim);
    font-size: 16px;
    cursor: pointer;
    padding: 2px 6px;
    line-height: 1;
    transition: color 0.2s;
  }
  .demo-modal__close:hover { color: var(--cream); }
  .demo-modal__frame { flex: 1; width: 100%; border: none; background: #fff; }
  .demo-modal__blocked {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--text-dim);
  }
  .demo-modal__blocked[hidden] { display: none; }
  .demo-modal__blocked a { color: var(--amber); }

  @media (max-width: 720px) {
    .built__grid { grid-template-columns: 1fr; }
    .demo-modal { inset: 0; }
  }
</style>

<script is:inline>
(function () {
  const modal     = document.getElementById('demo-modal');
  const overlay   = document.getElementById('demo-overlay');
  const frame     = document.getElementById('demo-frame');
  const titleEl   = document.getElementById('demo-modal-title');
  const linkEl    = document.getElementById('demo-modal-link');
  const closeBtn  = document.getElementById('demo-modal-close');
  const blocked   = document.getElementById('demo-modal-blocked');
  const blockedLink = document.getElementById('demo-modal-blocked-link');

  function openDemo(url, title) {
    titleEl.textContent = title;
    linkEl.href = url;
    blockedLink.href = url;
    frame.removeAttribute('hidden');
    blocked.hidden = true;
    frame.onload = function() {
      try {
        const loc = frame.contentWindow.location.href;
        if (!loc || loc === 'about:blank') showBlocked();
      } catch(e) {}
    };
    frame.onerror = showBlocked;
    frame.src = url;
    modal.hidden = false;
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function showBlocked() { frame.hidden = true; blocked.hidden = false; }
  function closeDemo() {
    modal.hidden = true;
    overlay.hidden = true;
    frame.src = '';
    frame.hidden = false;
    blocked.hidden = true;
    document.body.style.overflow = '';
  }
  document.querySelectorAll('.card__demo').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.dataset.url) openDemo(btn.dataset.url, btn.dataset.title);
    });
  });
  closeBtn.addEventListener('click', closeDemo);
  overlay.addEventListener('click', closeDemo);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeDemo();
  });
})();
</script>
