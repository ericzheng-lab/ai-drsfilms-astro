---
const departments = [
  { id: 'brand',    label: 'Brand' },
  { id: 'film',     label: 'Film' },
  { id: 'career',   label: 'Career' },
  { id: 'products', label: 'Products' },
  { id: 'aifilm',   label: 'AI-Film' },
  { id: 'system',   label: 'System' },
];
---
<section class="section ezos" id="ez-os" data-num="06">
  <div class="section__inner">
    <p class="eyebrow reveal">Operating System</p>
    <h2 class="section__title reveal reveal--title">EZ-OS</h2>
    <p class="section__sub reveal">I run production like software.</p>

    <div class="ezos__layout">
      <div class="ezos__copy">
        <p class="ezos__body reveal">
          A multi-agent operating system for a one-person studio.
          Six departments (Brand · Film · Career · Products · AI-Film · System),
          four named agents, dynamic subagents dispatched per task.
          Built on Hyperagent, run on Cloudflare, filed through Google Drive.
        </p>
        <p class="ezos__body reveal">
          Five AI shorts, two budgets, one breakdown — shipped in four weeks of agent runtime.
        </p>

        <blockquote class="ezos__quote reveal">
          The goal isn't automation. It's <em>leverage</em> —
          compounding creative output without compounding headcount.
        </blockquote>
      </div>

      <div class="ezos__diagram reveal" aria-hidden="true">
        <video
          class="ezos__video"
          src="/media/hero-ezos.mp4"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        ></video>
      </div>
    </div>
  </div>
</section>

<style>
  .ezos__layout {
    margin-top: 24px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }
  .ezos__copy { display: flex; flex-direction: column; gap: 22px; }
  .ezos__body {
    font-family: var(--font-ui);
    font-size: 15px;
    line-height: 1.75;
    color: var(--text);
    max-width: 56ch;
  }
  .ezos__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.4;
    color: var(--cream);
    border-left: 2px solid var(--amber);
    padding-left: 24px;
    margin-top: 16px;
    max-width: 38ch;
  }
  .ezos__quote em { color: var(--amber); font-style: italic; }

  .ezos__diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    overflow: hidden;
    position: relative;
    background: #050810;
  }
  .ezos__video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 860px) {
    .ezos__layout { grid-template-columns: 1fr; }
    .ezos__diagram { order: -1; margin-bottom: 16px; }
  }
</style>
