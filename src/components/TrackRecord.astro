---
const stats = [
  { num: '60+',      label: 'Countries Released',   sub: '$2.5M China · France · Denmark · Qatar co-production' },
  { num: '$8M+',     label: 'Commercial Portfolio',  sub: "Nike · Tencent · Riot · L'Oréal · BMW · miHoYo" },
  { num: 'Sundance', label: 'Grand Jury Nominee',    sub: 'Berlinale Panorama · Brief History of A Family' },
];
const clients = ['Nike','Tencent','Riot Games',"L'Oréal",'BMW','miHoYo','Estée Lauder','Final Frontier'];
const affiliations = [
  { name: 'Hyperagent', role: 'Founding 500', note: 'First 500 power users on the platform.' },
  { name: 'Gold House',     role: 'Member',      note: null },
  { name: 'Wonder Studios', role: 'Community',   note: null },
];
---
<section class="section track" id="track-record">
  <div class="section__inner">
    <p class="eyebrow reveal">Track Record</p>
    <h2 class="section__title reveal reveal--title">Fifteen Years</h2>

    <div class="track__stats">
      {stats.map((s, i) => (
        <article class="stat reveal reveal--stat" style={`--stagger:${i}`}>
          <div class="stat__num">{s.num}</div>
          <div class="stat__label">{s.label}</div>
          <div class="stat__sub">{s.sub}</div>
        </article>
      ))}
    </div>

    <hr class="rule reveal reveal--rule" />

    <div class="track__clients reveal">
      <p class="track__clients-label">Selected Clients</p>
      <p class="track__clients-list">
        {clients.map((c, i) => (
          <>
            <span>{c}</span>
            {i < clients.length - 1 && <span class="dot" aria-hidden="true"> · </span>}
          </>
        ))}
      </p>
    </div>

    <hr class="rule reveal reveal--rule" />

    <div class="affiliations reveal">
      <p class="affiliations__label">Affiliations</p>
      <ul class="affiliations__list">
        {affiliations.map((a, i) => (
          <li class="aff reveal reveal--aff" style={`--stagger:${i}`}>
            <span class="aff__name">{a.name}</span>
            <span class="aff__sep" aria-hidden="true">—</span>
            <span class="aff__role">{a.role}</span>
            {a.note && <span class="aff__note">{a.note}</span>}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .track { padding-top: calc(var(--section-pad) * 0.85); }

  .track__stats {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(28px, 4vw, 56px);
    border-top: 1px solid var(--rule);
    padding-top: 56px;
  }
  .stat__num {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(48px, 5.5vw, 80px);
    color: var(--amber);
    line-height: 1;
    letter-spacing: -0.005em;
  }
  .stat__label {
    margin-top: 14px;
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cream);
  }
  .stat__sub {
    margin-top: 8px;
    font-family: var(--font-ui);
    font-size: 12.5px;
    color: var(--text-dim);
    line-height: 1.5;
  }
  .track__clients-label {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .track__clients-list {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(18px, 2.2vw, 26px);
    color: var(--cream);
    line-height: 1.6;
  }
  .track__clients-list .dot { color: var(--amber-d); }

  .affiliations__label {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 20px;
  }
  .affiliations__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 40px);
  }
  .aff {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    padding-top: 18px;
    border-top: 1px solid rgba(227, 168, 104, 0.18);
  }
  .aff__name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(18px, 2vw, 22px);
    color: var(--cream);
    line-height: 1;
  }
  .aff__sep { color: var(--amber-d); font-family: var(--font-ui); font-size: 13px; }
  .aff__role {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .aff__note {
    flex-basis: 100%;
    font-family: var(--font-ui);
    font-size: 11.5px;
    color: var(--text-dim);
    line-height: 1.5;
    margin-top: 2px;
  }

  @media (max-width: 720px) {
    .track__stats { grid-template-columns: 1fr; gap: 32px; }
    .stat { padding-bottom: 28px; border-bottom: 1px solid var(--rule-soft); }
    .stat:last-child { border-bottom: 0; padding-bottom: 0; }
    .affiliations__list { grid-template-columns: 1fr; gap: 18px; }
  }
</style>
