---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrackRecord from '../components/TrackRecord.astro';
import WhatIBuilt from '../components/WhatIBuilt.astro';
import Films from '../components/Films.astro';
import ToolStack from '../components/ToolStack.astro';
import EzOS from '../components/EzOS.astro';
import Contact from '../components/Contact.astro';
---
<Base>
  <Fragment slot="head">
    <title>Eric Zheng — Film Producer · AI Builder</title>
    <meta
      name="description"
      content="Film producer with Sundance and Berlinale credits who builds AI production systems. 15 years. $8M+ campaigns. I connect both worlds."
    />
    <meta property="og:title" content="Eric Zheng — Film Producer · AI Builder" />
    <meta
      property="og:description"
      content="Film producer with Sundance and Berlinale credits who builds AI production systems."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ai.drsfilms.com" />

    <script type="importmap" is:inline>
      {
        "imports": {
          "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
          "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
        }
      }
    </script>
  </Fragment>

  <Nav />

  <main>
    <Hero />
    <TrackRecord />
    <WhatIBuilt />
    <Films />
    <ToolStack />
    <EzOS />
    <Contact />
  </main>

  <script is:inline>
    // Reveal-on-scroll: opacity + translateY into view, vanilla IntersectionObserver.
    (function () {
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -80px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    })();
  </script>
</Base>
